# ===========================================
# Neon PostgreSQL
# ===========================================
# Pooled connection（アプリ実行時に使用）
DATABASE_URL="postgresql://[user]:[password]@[endpoint-id].ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Direct connection（Prisma マイグレーション時に使用）
DIRECT_URL="postgresql://[user]:[password]@[endpoint-id].ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ===========================================
# 認証
# ===========================================
JWT_SECRET="your-secret-key-here"
ADMIN_PASSWORD="your-admin-password"

# ===========================================
# AWS S3（画像アップロード用）
# ===========================================
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_REGION="ap-northeast-1"
AWS_S3_BUCKET="your-bucket-name"
