generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Post {
  id             Int        @id @default(autoincrement())
  title          String
  slug           String     @unique
  content        String
  excerpt        String?
  eyecatch       String?
  published      Boolean    @default(false)
  isPickup       Boolean    @default(false)
  showForGen     Boolean    @default(true)
  showForVip     Boolean    @default(true)
  showForVC      Boolean    @default(false)
  scheduledAt    DateTime?
  views          Int        @default(0)
  writerId       Int?
  writer         Writer?    @relation(fields: [writerId], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  clicks         Click[]
  pageViews      PageView[]

  @@index([published, createdAt])
  @@map("posts")
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String

  @@map("admins")
}

model Click {
  id        Int      @id @default(autoincrement())
  postId    Int
  url       String
  label     String?
  source    String?  // "gen" | "vip" | "vc" クリック元の媒体
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("clicks")
}

model PageView {
  id        Int      @id @default(autoincrement())
  postId    Int
  source    String?  // "gen" | "vip" | "vc" 閲覧元（一般会員/正会員/仮想通貨長者）
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("page_views")
}

model CustomEditor {
  id    Int    @id @default(autoincrement())
  name  String
  icon  String
  html  String
  order Int    @default(0)

  @@map("custom_editors")
}

model Banner {
  id       Int    @id @default(autoincrement())
  label    String
  url      String
  imageUrl String?
  media    String @default("all") // "all" | "gen" | "vip" | "vc" 表示対象の媒体
  order    Int    @default(0)

  @@map("banners")
}

model Writer {
  id        Int     @id @default(autoincrement())
  name      String
  avatarUrl String?
  order     Int     @default(0)
  posts     Post[]

  @@map("writers")
}
